rules_version = '2';

// ============================================================
// UCENM — Reglas de seguridad de Firestore
// ============================================================
// Lectura: pública para todos (alumnos no necesitan cuenta para leer).
// Escritura:
//   - clases / tareas / anuncios  -> SOLO maestro (login con
//     correo+contraseña, proveedor "password")
//   - tareasCompletadas           -> maestro O alumno (sesión anónima),
//     porque el check de "tarea completada" es compartido para todos.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /ucenm/tareasCompletadas {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /ucenm/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }
  }
}
